<!--pages/4_3/4_3.wxml-->
<navigation-bar title="4_3" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<view class="box">
<view class="title">修改字体样式和大小</view>
<text style="font-style: {{myitalic}};font-weight: {{mybold}};text-decoration: {{myunderline}};font-size: {{myFontSize}};">上海大学</text>
<checkbox-group bindchange="checkboxChange">
<checkbox value="isBold">加粗</checkbox>
<checkbox value="isItalic">倾斜</checkbox>
<checkbox value="isUnderline">下划线</checkbox>
</checkbox-group>
<radio-group bindchange="radioChange">
<radio value="15px">15px</radio>
<radio value="25px" checked="true">25px</radio>
<radio value="35px">35px</radio>
</radio-group>
</view>