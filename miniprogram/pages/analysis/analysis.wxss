page {
  background-color: #f6f7f9;
  color: #333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.container {
  padding: 30rpx;
}

/* 图表卡片容器 */
.chart-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  height: 500rpx; /* 给卡片一个固定高度 */
  position: relative; /* 确保内部绝对定位的 canvas 能找到参考系 */
}

.chart-card .title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
}

.chart-card .title::before {
  content: "";
  width: 8rpx;
  height: 32rpx;
  background: #0052d9;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* 图表占位区域（如果你还没装ECharts，这里会显示一个漂亮的占位） */
ec-canvas {
  width: 100%;
  height: 100%;
  display: block; /* 确保是块级元素 */
}

/* 数据表格区域 */
.data-table {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.table-header {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  background: #f8f9fb;
  border-radius: 16rpx;
  margin-bottom: 10rpx;
}

.table-header text {
  font-size: 24rpx;
  color: #86868b;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.table-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f2f2f7;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row text:first-child {
  font-size: 28rpx;
  color: #1d1d1f;
  font-weight: 400;
}

/* 绩点数字突出显示 */
.gpa-bold {
  font-size: 34rpx;
  font-weight: 700;
  color: #0052d9;
  font-family: 'DIN Alternate', 'Courier New', Courier, monospace;
}

/* 空状态 */
.empty-tip {
  padding: 100rpx 0;
  text-align: center;
  color: #b0b0b8;
  font-size: 26rpx;
}