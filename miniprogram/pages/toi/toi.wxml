<!--pages/toi/toi.wxml-->
<navigation-bar title="toi" back="{{true}}" color="white" background="#F00"></navigation-bar>
<!-- index.wxml -->
<view class="container">
  <!-- 横向导航 -->
  <canvas 
    canvas-id="myCanvas"
    style="width: 100%; height: 80px;"
    bindtouchstart="handleTap"
  ></canvas>
  
  <!-- 内容展示区域 -->
  <view class="content">
    <block wx:for="{{steps}}" wx:key="index">
      <view wx:if="{{index === currentIndex}}" class="content-item">
        {{item.content}}
      </view>
    </block>
  </view>
</view>