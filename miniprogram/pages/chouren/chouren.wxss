/* index.wxss */
page {
  background-color: #f8f8f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}
.subtitle {
  font-size: 24rpx;
  color: #888;
}

/* --- 转盘样式 --- */
.turntable-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
  margin-bottom: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.turntable {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 10rpx solid #fff;
  box-shadow: 0 0 20rpx rgba(0,0,0,0.1);
  position: relative;
  /* background由JS动态生成conic-gradient */
}

/* 转盘内的文字 */
.label {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1;
}
.label text {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 1px 1px 2px rgba(0,0,0,0.5);
  white-space: nowrap;
}

/* --- 指针样式 --- */
.pointer-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  pointer-events: none; /* 让点击穿透 */
}

/* 指针头 */
.pointer {
  width: 30rpx;
  height: 80rpx;
  background: #ff4d4f;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -100%) translateY(-20rpx); /* 定位到圆心上方 */
  clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
}
/* 指针中心圆点 */
.pointer-center {
  width: 40rpx;
  height: 40rpx;
  background: #ff4d4f;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 4rpx solid #fff;
}

/* --- 按钮与输入 --- */
.start-btn {
  background-color: #07c160;
  color: white;
  width: 80%;
  border-radius: 50rpx;
  font-weight: bold;
  box-shadow: 0 5rpx 15rpx rgba(7, 193, 96, 0.3);
}

.divider {
  width: 100%;
  height: 1px;
  background: #e0e0e0;
  margin: 40rpx 0;
}

.input-section {
  display: flex;
  width: 100%;
  margin-bottom: 30rpx;
}
.input-box {
  flex: 1;
  background: white;
  padding: 15rpx 20rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  border: 1px solid #ddd;
}
.add-btn {
  background: #333;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* --- 预设列表 (仿图) --- */
.preset-section {
  width: 100%;
}
.preset-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}
.grid-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr); /* 三列布局 */
  gap: 20rpx;
}

.grid-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 15rpx;
  border-radius: 8rpx;
  border: 1px solid transparent;
}
/* 选中状态 */
.grid-item.active {
  border-color: #07c160;
  background-color: #e6f7ef;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ccc;
  border-radius: 4rpx;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.checkbox.checked {
  background-color: #07c160;
  border-color: #07c160;
}
.check-mark {
  color: white;
  font-size: 24rpx;
  line-height: 24rpx;
}
.item-name {
  font-size: 28rpx;
  color: #333;
}
/* 修改原有的 .grid-item 样式 */
.grid-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 15rpx 20rpx; /* 增加左右内边距 */
  border-radius: 8rpx;
  border: 1px solid transparent;
  position: relative; /* 核心：开启相对定位 */
  transition: all 0.2s;
}

/* 选项名称样式 */
.item-name {
  font-size: 28rpx;
  color: #333;
  flex: 1; /* 核心：占据剩余空间，将删除按钮挤到右侧 */
}

/* 修改点：删除按钮样式 */
.delete-btn {
  color: #ff4d4f; /* 变红 */
  font-size: 40rpx; /* 调大一点方便点击 */
  font-weight: bold;
  padding: 0 10rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 可选：鼠标悬停或点击时的反馈 */
.delete-btn:active {
  opacity: 0.5;
}
.preset-header-bar {
  display: flex;
  justify-content: space-between; /* 左右两端对齐 */
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.preset-title {
  font-size: 28rpx;
  color: #666;
  /* 去掉原本的 margin-bottom，交给 header-bar 管理 */
  margin-bottom: 0; 
}

/* 右侧操作区 */
.header-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  font-size: 26rpx;
  color: #07c160; /* 微信绿，表示操作 */
  padding: 10rpx;
  font-weight: bold;
}
.action-btn:active {
  opacity: 0.6;
}

.divider-vertical {
  color: #ccc;
  font-size: 24rpx;
  margin: 0 5rpx;
}

