/* pages/index/index.wxss */
.image-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    padding: 10rpx;
  }
  
  .image-item {
    width: calc(33.333% - 10rpx);
    height: 0;
    padding-bottom: 33.333%; /* 保持正方形 */
    margin-bottom: 10rpx;
    position: relative;
  }
  
  .image-item image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8rpx;
  }
