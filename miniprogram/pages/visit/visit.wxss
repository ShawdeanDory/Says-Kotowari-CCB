page {
  background-color: #f8f9fa;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部信息 */
.profile-header {
  background: #fff;
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar {
  width: 90rpx; height: 90rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #eee;
}

.name { font-size: 32rpx; font-weight: bold; color: #333; }
.desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 课表容器 */
.timetable-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 星期表头 */
.week-header {
  display: flex;
  height: 80rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.corner-box { width: 70rpx; flex-shrink: 0; }

.week-cells {
  flex: 1;
  display: flex;
}

.week-cell {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

/* 滚动区 */
.course-scroll {
  flex: 1;
}

.course-body {
  display: flex;
  position: relative;
  width: 100%;
}

/* 侧边栏 */
.sidebar {
  width: 70rpx;
  background: #fdfdfd;
  display: flex;
  flex-direction: column;
}

.sidebar-node {
  height: 110rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  color: #999;
}

/* 课程网格 */
.course-grid {
  flex: 1;
  position: relative;
  background: #fff;
}

.grid-row-line {
  height: 110rpx;
  border-bottom: 1rpx dashed #f5f5f5;
  box-sizing: border-box;
}

/* 课程卡片 */
.course-card {
  position: absolute;
  width: 20%; /* 100% / 5天 */
  padding: 4rpx;
  box-sizing: border-box;
  z-index: 10;
}

.card-inner {
  height: 100%;
  width: 100%;
  border-radius: 8rpx;
  padding: 8rpx;
  box-sizing: border-box;
  color: #fff;
  display: flex;
  flex-direction: column;
  box-shadow: 2rpx 4rpx 10rpx rgba(0,0,0,0.1);
}

.c-name {
  font-size: 20rpx;
  font-weight: bold;
  line-height: 1.2;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.c-room {
  font-size: 18rpx;
  margin-top: 6rpx;
  opacity: 0.9;
}

/* 悬浮按钮 */
.float-back-btn {
  position: fixed;
  bottom: 50rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.8);
  color: #fff;
  padding: 16rpx 50rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  z-index: 99;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.3);
}
/* ===== 以下样式追加到 visit.wxss 末尾 ===== */

/* 周切换栏 */
.week-switcher {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  padding: 12rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.week-switcher-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}
.week-switcher-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}
.week-switcher-text.is-current { color: #6c5ce7; }

/* 切换箭头按钮 */
.week-nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0eeff;
  border-radius: 14rpx;
}
.week-nav-btn:active { background: #d4c9ff; }
.nav-arrow {
  font-size: 40rpx;
  color: #6c5ce7;
  font-weight: 700;
  line-height: 1;
}

/* 本周无课空状态 */
.empty-week {
  position: absolute;
  top: 200rpx;
  left: 0; right: 0;
  display: flex;
  justify-content: center;
}
.empty-week-text {
  font-size: 28rpx;
  color: #ccc;
}
