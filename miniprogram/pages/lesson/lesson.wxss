/* pages/lesson/lesson.wxss */

/* === 核心修复：防止全局样式干扰 === */
page {
  background-color: #f7f8fa;
  width: 100%;
  height: 100%;
  overflow: hidden; /* 防止整个页面滚动 */
}

/* 改名后的主容器 */
.main-box {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100vw; /* 强制占满屏幕宽度 */
  box-sizing: border-box;
  align-items: stretch; /* ⚠️ 关键：强制拉伸宽度，不许居中挤压 */
}

/* === 顶部卡片 === */
.user-card-header {
  margin: 0 30rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex; justify-content: space-between; align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.03);
  z-index: 10; flex-shrink: 0;
}

.user-info { display: flex; align-items: center; }

/* 头像防扁终极版 */
.avatar-box { 
  width: 100rpx; height: 100rpx; margin-right: 24rpx; 
  flex-shrink: 0; flex-grow: 0; flex-basis: 100rpx;
}
.avatar-btn {
  padding: 0 !important; margin: 0 !important;
  width: 100rpx !important; height: 100rpx !important;
  border-radius: 50%;
  background: #eee;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  display: flex; justify-content: center; align-items: center;
  overflow: hidden;
}
.avatar-btn::after { border: none; }
.avatar-img { width: 100%; height: 100%; object-fit: cover; }

.greeting-text { display: flex; flex-direction: column; justify-content: center; }

/* 昵称输入框 */
.name-input {
  font-size: 34rpx; font-weight: 700; color: #333;
  margin-bottom: 6rpx; height: 48rpx; min-width: 200rpx;
}
.name-placeholder { color: #ccc; font-weight: normal; font-size: 30rpx; }
.h2 { font-size: 24rpx; color: #999; }

.action-btn {
  background: linear-gradient(135deg, #6c5ce7, #a29bfe);
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  display: flex; 
  align-items: center;
  box-shadow: 0 6rpx 16rpx rgba(108, 92, 231, 0.3);
  
  /* ▼▼▼ 核心修复：防止文字换行及按钮被挤压 ▼▼▼ */
  white-space: nowrap;  /* 强制文字不换行 */
  flex-shrink: 0;       /* 禁止按钮缩小 */
  margin-left: 20rpx;   /* 跟左边保持点距离 */
}
.action-btn:active { transform: scale(0.95); opacity: 0.9; }
.action-btn text { color: #fff; font-size: 26rpx; font-weight: 600; }
.btn-icon { font-size: 32rpx !important; margin-right: 6rpx; margin-top: -4rpx; }

/* === 日期栏 === */
.date-bar { 
  display: flex; align-items: center; 
  padding: 20rpx 0; /* 修改：去掉左右 padding，完全交由内部控制 */
  background: transparent; margin-top: 10rpx;
  width: 100%; box-sizing: border-box; flex-shrink: 0;
}

.month-box { 
  width: 80rpx; /* 修改：必须与下方 sidebar 宽度 80rpx 严格一致 */
  display: flex; flex-direction: column; align-items: center; 
  border-right: 2rpx solid #e0e0e0; 
  box-sizing: border-box; /* 去掉原有的 margin-right，保证对齐不偏移 */
  flex-shrink: 0; 
}
.month-num { font-size: 40rpx; font-weight: 800; color: #333; line-height: 1; }
.month-cn { font-size: 22rpx; color: #999; }
.week-row { 
  flex: 1; 
  display: flex; 
  justify-content: space-around; 
  margin-right: 16rpx; /* 修改：与下方 course-container 保持一样的右边距 */
}
.week-item { flex: 1; display: flex; flex-direction: column; align-items: center; height: 80rpx; justify-content: center; border-radius: 16rpx; position: relative; }
.week-name { font-size: 26rpx; color: #666; font-weight: 500; }
.active-day { background-color: #ffffff; box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05); }
.active-day .week-name { color: #6c5ce7; font-weight: 800; }
.indicator { width: 8rpx; height: 8rpx; background: #6c5ce7; border-radius: 50%; position: absolute; bottom: 10rpx; }

/* === 课表区域 (关键修复区) === */
.scroll-area {
  flex: 1; /* 占满剩余高度 */
  width: 100%; /* 占满宽度 */
  overflow-y: scroll; -webkit-overflow-scrolling: touch;
  background: #fff;
  border-top-left-radius: 40rpx; border-top-right-radius: 40rpx;
  padding-top: 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.02);
  box-sizing: border-box;
  position: relative;
}

.timetable-body { 
  display: flex; 
  position: relative; 
  padding-bottom: 60rpx;
  width: 100%; /* 确保内部撑开 */
}

.sidebar { width: 80rpx; display: flex; flex-direction: column; flex-shrink: 0; }
.sidebar-item { height: 110rpx; display: flex; justify-content: center; align-items: center; }
.node-num { font-size: 24rpx; color: #999; font-weight: 600; }

.course-container { 
  flex: 1; /* 自动占据剩余宽度 */
  position: relative; 
  margin-right: 16rpx;
  min-height: 1000rpx; 
}

.grid-line { position: absolute; left: 0; right: 0; height: 1rpx; border-bottom: 2rpx dashed #f0f0f0; z-index: 1; }

.course-card {
  position: absolute;
  width: 19.2%; /* 修改：原先是 13.5%，现在一行5个，大约占 19.2% 以留出缝隙 */
  border-radius: 12rpx; overflow: hidden; z-index: 10;
  box-shadow: 4rpx 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
  display: flex !important; visibility: visible !important;
}
.course-card:active { transform: scale(0.95); opacity: 0.9; }
.card-inner { width: 100%; height: 100%; padding: 8rpx 6rpx; box-sizing: border-box; display: flex; flex-direction: column; }
.c-name { font-size: 22rpx; color: #fff; font-weight: 700; line-height: 1.35; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; overflow: hidden; text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1); }
.c-room { margin-top: 6rpx; font-size: 18rpx; color: rgba(255, 255, 255, 0.9); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }